APP_ID=app_02bd6decc052cfd1dfa2948744af6c6f
VITE_WORLD_APP_ID=app_02bd6decc052cfd1dfa2948744af6c6f
DEV_PORTAL_API_KEY=your_world_developer_portal_api_key
RESEND_API_KEY=your_resend_api_key
ORDER_NOTIFICATION_EMAIL=brianokindo2022@gmail.com
ORDER_EMAIL_FROM=TMpesa <onboarding@resend.dev>
WORLD_NOTIFICATION_API_KEY=your_world_notification_api_key

# Order + World ID record store. Upstash Redis is preferred; Vercel Blob
# is the fallback when Redis is absent. Set one or the other.
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
BLOB_READ_WRITE_TOKEN=your_vercel_blob_read_write_token

# World ID high-value verification (api/_lib/worldId.js). SERVER ONLY —
# never prefix VITE_, or Vite would inline this private key into the
# client bundle. Obtain by rotating the RP signing key in the Developer
# Portal; store only in Vercel env, never commit the real value. Until
# this is set (with a store above), the high-value gate is inert and
# orders flow unchanged. Optional: WORLD_ID_HIGH_VALUE_KES overrides the
# 10000 KES threshold.
WORLD_ID_RP_SIGNING_KEY=your_rp_signing_key_hex
# WORLD_ID_HIGH_VALUE_KES=10000

# Admin identity (api/_lib/adminAuth.js) — there is no admin login
# form or credential of any kind. A request is an administrator if and
# only if its SIWE-verified World App wallet appears here. Comma-
# separated; unset entirely to keep the single built-in default wallet
# recognized (see DEFAULT_ADMIN_WALLET in api/_lib/adminAuth.js). Set
# this only in Vercel's environment variables, never commit real values.
ADMIN_WALLET_ADDRESSES=0xFirstOperatorWallet,0xSecondOperatorWallet
ADMIN_SESSION_SECRET=a_long_random_string_for_signing_session_cookies
