# Admin identity (api/_lib/adminAuth.js) — there is no admin login
# form or credential of any kind. A request is an administrator if and
# only if its SIWE-verified World App wallet appears here. Comma-
# separated; unset entirely to keep the single built-in default wallet
# recognized (see DEFAULT_ADMIN_WALLET in api/_lib/adminAuth.js). Set
# this only in Vercel's environment variables, never commit real values.
ADMIN_WALLET_ADDRESSES=0xFirstOperatorWallet,0xSecondOperatorWallet
ADMIN_SESSION_SECRET=a_long_random_string_for_signing_session_cookies
